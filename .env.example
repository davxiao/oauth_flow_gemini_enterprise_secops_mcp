# ============================================================================
# Agentic SOC Agent - Environment Configuration
# ============================================================================
# Copy this file to .env and fill in your actual values
# Variables are organized by deployment stage
# ============================================================================

# ----------------------------------------------------------------------------
# STAGE 1: Prerequisites (Set BEFORE deployment)
# ----------------------------------------------------------------------------
# These are required by `make agent-engine-deploy`

# Google Cloud Project Configuration
GCP_PROJECT_ID=secops-demo-env
GCP_PROJECT_NUMBER=813924125873
GCP_LOCATION=us-central1
#GCP_LOCATION=us-east4
GCP_STAGING_BUCKET=gs://secops-demo-env-staging

# Chronicle SIEM Configuration
CHRONICLE_PROJECT_ID=secops-demo-env
CHRONICLE_CUSTOMER_ID=a13f6726-efed-452e-9008-8fe0d3cb0f75
CHRONICLE_LOCATION=us


# SOAR Platform Configuration
SOAR_URL=https://YOURS.siemplify-soar.com:443
SOAR_API_KEY=12345678-dcba-4321-9876-fdedcba12345
SOAR_APP_KEY=12345678-dcba-4321-9876-fdedcba12345

# Google Threat Intelligence (VirusTotal)
GTI_API_KEY=YOURS


# ----------------------------------------------------------------------------
# Agent Engine Configuration
# ----------------------------------------------------------------------------

# ----------------------------------------------------------------------------
# STAGE 2: Deployment Outputs (Auto-populated by `make agent-engine-deploy`)
# ----------------------------------------------------------------------------

# simple onemcp passthrough agent (TEMP)
AGENT_ENGINE_RESOURCE_NAME=projects/813924125873/locations/us-central1/reasoningEngines/7350332538461618176
AGENT_ENGINE_ID=7350332538461618176

# OneMCP SecOps Agent with OAuth Passthrough
# projects/813924125873/locations/us-central1/reasoningEngines/7350332538461618176

AGENTSPACE_APP_ID=gemini-enterprise-oauth-pa_1774404575457

# ----------------------------------------------------------------------------
# STAGE 3: AgentSpace Integration
# ----------------------------------------------------------------------------
# PREREQUISITE: AGENTSPACE_APP_ID must be created before registration
# Option 1: Create manually via Google Cloud Console (see README step 6)
# Option 2: Auto-create with `python manage.py agentspace create-app`
# AGENTSPACE_APP_ID=your-app-id

# Optional AgentSpace hierarchy (only set if customizing)
# AGENTSPACE_COLLECTION=default_collection
# AGENTSPACE_ASSISTANT=default_assistant

# OUTPUT: Auto-populated by `make agentspace-register`
# AGENTSPACE_AGENT_ID=your-agent-id

# ----------------------------------------------------------------------------
# STAGE 4: OAuth Outputs (Auto-populated by `make oauth-setup`)
# ----------------------------------------------------------------------------
# OAUTH_AUTH_ID=your-auth-id
# OAUTH_CLIENT_ID=your-client-id.apps.googleusercontent.com
# OAUTH_CLIENT_SECRET=your-client-secret
# OAUTH_AUTH_URI=https://accounts.google.com/o/oauth2/auth
# OAUTH_TOKEN_URI=https://oauth2.googleapis.com/token


